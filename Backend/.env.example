# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Korean Tourism Organization Public Data API
TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorWithService2
TOUR_API_KEY=your-tour-api-key-here
TOUR_API_MOBILE_OS=ETC
TOUR_API_MOBILE_APP=TravUs

# Redis (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OPEN AI API키
OPENAI_API_KEY=your-openai-api-key-here

# ngrok 사용 시 설정
# ALLOWED_HOSTS=localhost,127.0.0.1,your-ngrok-url.ngrok-free.dev
# GMS_KEY=your-gms-key-here
